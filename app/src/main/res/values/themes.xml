<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.MovieWatchlist" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/silver_metallic</item>
        <item name="colorOnPrimary">@color/deep_obsidian</item>
        <item name="android:windowBackground">@color/deep_obsidian</item>
        <item name="colorSurface">@color/dark_charcoal</item>
        <item name="colorOnSurface">@color/white</item>
        <item name="colorOnSurfaceVariant">@color/steel_grey</item>
        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:textColorSecondary">@color/steel_grey</item>
        <item name="android:editTextColor">@color/white</item>
        <item name="android:textColorHint">@color/steel_grey</item>
        <item name="android:navigationBarColor">@color/deep_obsidian</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o">false</item>
    </style>

    <style name="Theme.MovieWatchlist" parent="Base.Theme.MovieWatchlist" />

    <style name="Theme.MovieWatchlist.NoActionBar" parent="Base.Theme.MovieWatchlist">
        <item name="android:statusBarColor">@color/deep_obsidian</item>
    </style>

</resources>